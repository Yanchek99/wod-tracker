{
  "name": "wod-tracker",
  "description": "Open source Crossfit WOD tracker",
  "repository": "https://github.com/yanchek99/wod-tracker",
  "scripts": {
    "postdeploy": "bundle exec rails db:seed"
  },
  "env": {
    "RAILS_MASTER_KEY": {
      "description": "The Rails master key used to decrypt application credentials.",
      "required": true
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "eco"
    }
  },
  "addons": [
    "heroku-postgresql"
  ],
  "stack": "heroku-26",
  "buildpacks": [
    {
      "url": "heroku/nodejs"
    },
    {
      "url": "heroku/ruby"
    }
  ]
}
